# Copy this file to ".env.local" and fill in the values.

# 1) Google Gemini (free, no credit card): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_free_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001

# 2) Upstash Vector (free): https://console.upstash.com
#    Create a Vector index with: Dimensions = 768, Metric = COSINE
UPSTASH_VECTOR_REST_URL=your_upstash_vector_url
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token
